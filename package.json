{
  "name": "decisionnode",
  "version": "0.6.0",
  "description": "Record structured decisions once, search them from all your AI coding tools — a shared structured semantic memory store across Claude Code, Cursor, Windsurf, Antigravity, and every MCP client.",
  "keywords": [
    "decisions",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "cursor",
    "windsurf",
    "antigravity",
    "gemini",
    "embeddings",
    "semantic-search",
    "rag"
  ],
  "author": "DecisionNode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decisionnode/DecisionNode.git"
  },
  "homepage": "https://decisionnode.dev",
  "bugs": {
    "url": "https://github.com/decisionnode/decisionnode/issues"
  },
  "type": "module",
  "bin": {
    "decide": "./dist/cli.js",
    "decisionnode": "./dist/cli.js",
    "decide-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-ui.mjs",
    "build:ts": "tsc",
    "build:ui": "node scripts/build-ui.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^20.19.27",
    "cytoscape": "^3.33.2",
    "cytoscape-fcose": "^2.2.0",
    "esbuild": "^0.27.7",
    "preact": "^10.29.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3",
    "umap-js": "^1.4.0",
    "vitest": "^4.1.2"
  }
}
