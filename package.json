{
  "name": "decisionnode",
  "version": "0.5.0",
  "description": "Record a decision, embed it as a vector, search it later. CLI + MCP server for AI tools.",
  "keywords": [
    "decisions",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "cursor",
    "windsurf",
    "antigravity",
    "gemini",
    "embeddings",
    "semantic-search",
    "rag"
  ],
  "author": "DecisionNode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/decisionnode/decisionnode"
  },
  "homepage": "https://decisionnode.dev",
  "bugs": {
    "url": "https://github.com/decisionnode/decisionnode/issues"
  },
  "type": "module",
  "bin": {
    "decide": "./dist/cli.js",
    "decisionnode": "./dist/cli.js",
    "decide-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  }
}
